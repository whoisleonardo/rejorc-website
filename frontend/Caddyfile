# Quando ha outro proxy na frente (rede interna), preserva o IP real do
# visitante no X-Forwarded-For. Em acesso direto isso nao tem efeito.
{
	servers {
		trusted_proxies static private_ranges
	}
}

{$DOMAIN} {
	encode gzip

	handle /api/* {
		reverse_proxy backend:4000
	}

	handle /uploads/* {
		reverse_proxy backend:4000
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
