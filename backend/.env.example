# Porta da API
PORT=4000

# URL do frontend (para CORS). Em producao, coloque o dominio real.
FRONTEND_URL=http://localhost:5173

# Segredo usado para assinar os tokens de login. TROQUE isso em producao
# por uma string longa e aleatoria (ex: rode `openssl rand -hex 32`).
JWT_SECRET=troque-este-valor-por-um-segredo-longo-e-aleatorio

# Tempo de expiracao do login
JWT_EXPIRES_IN=8h

# Dados do primeiro usuario administrador, criado pelo `npm run seed`
ADMIN_NAME=Administradora REJORC
ADMIN_EMAIL=admin@rejorc.ufpr.br
ADMIN_PASSWORD=troque-esta-senha-123

# --- Envio de newsletter (via Brevo - https://www.brevo.com) ---
# Sem esses valores o painel funciona normalmente, so a aba "Enviar" da
# newsletter fica desativada com instrucoes de configuracao.
# BREVO_API_KEY: crie em Brevo > Settings > SMTP & API > API Keys.
# NEWSLETTER_FROM_EMAIL: remetente verificado no Brevo (Senders & IPs).
BREVO_API_KEY=
NEWSLETTER_FROM_EMAIL=
NEWSLETTER_FROM_NAME=REJORC

# URL publica da API em producao (para as imagens dos e-mails). Em
# desenvolvimento pode deixar vazio.
API_PUBLIC_URL=
